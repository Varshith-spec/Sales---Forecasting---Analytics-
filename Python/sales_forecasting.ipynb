import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# Load dataset
df = pd.read_csv("../data/sales_data.csv")

# Data cleaning
df = df.drop_duplicates()
df["order_date"] = pd.to_datetime(df["order_date"])
df["month"] = df["order_date"].dt.month
df["year"] = df["order_date"].dt.year

print("First 5 rows:")
print(df.head())

# Total revenue
total_revenue = df["sales_amount"].sum()
print("Total Revenue:", total_revenue)

# Revenue by category
category_sales = df.groupby("product_category")["sales_amount"].sum()
print("\nSales by Product Category:")
print(category_sales)

# Monthly sales trend
monthly_sales = df.groupby("order_date")["sales_amount"].sum()

plt.figure(figsize=(10, 5))
plt.plot(monthly_sales.index, monthly_sales.values, marker="o")
plt.title("Sales Trend Over Time")
plt.xlabel("Date")
plt.ylabel("Revenue")
plt.xticks(rotation=45)
plt.tight_layout()
plt.show()

# Forecasting with Prophet
try:
    from prophet import Prophet

    forecast_df = df.groupby("order_date")["sales_amount"].sum().reset_index()
    forecast_df.columns = ["ds", "y"]

    model = Prophet()
    model.fit(forecast_df)

    future = model.make_future_dataframe(periods=90)
    forecast = model.predict(future)

    model.plot(forecast)
    plt.title("Sales Forecast for Next 90 Days")
    plt.show()

except ImportError:
    print("Prophet is not installed. Run: pip install prophet")

